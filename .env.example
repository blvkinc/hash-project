# Database
FIM_DATABASE_PATH=file_monitor.db

# Hashing
FIM_HASH_MODE=hybrid
FIM_HASH_ALGORITHM=xxh3_128
FIM_SECURITY_HASH_ALGORITHM=blake3
FIM_HASH_CHUNK_SIZE=4194304
FIM_BLAKE3_MAX_THREADS=1
FIM_BASELINE_CAPTURE_MODE=hash_first
FIM_BASELINE_HASH_WORKERS=16
FIM_BASELINE_COMMIT_BATCH_SIZE=1000

# Analysis providers
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=gemma4:latest
FIM_OLLAMA_TIMEOUT=45
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Background analysis
FIM_ANALYSIS_BACKLOG_THRESHOLD=500
FIM_ANALYSIS_BATCH=15
FIM_ANALYSIS_COALESCE_WINDOW_SECONDS=120
FIM_ANALYSIS_PENDING_HARD_CAP=5000
FIM_BASELINE_ANALYSIS_MODE=suspicious

# MemPalace agent
FIM_MEMPALACE_ENABLED=true
FIM_MEMPALACE_PATH=.mempalace_fim
FIM_MEMPALACE_BACKEND=sqlite_exact
FIM_MEMPALACE_COLLECTION=fim_file_memories
FIM_MEMPALACE_AGENT_MODE=auto
FIM_MEMPALACE_AGENT_LLM=true
FIM_MEMPALACE_BASELINE_ENABLED=true
FIM_MEMPALACE_BASELINE_MAX_ENTRIES=5000
FIM_MEMPALACE_BASELINE_BATCH_SIZE=64
FIM_MEMPALACE_BASELINE_INCLUDE_TIER4=false

# Agent investigation policy
FIM_AGENT_INVESTIGATION_ENABLED=true
FIM_AGENT_INVESTIGATION_MIN_RISK=7
FIM_AGENT_INVESTIGATION_MAX_PER_BATCH=8
FIM_AGENT_INVESTIGATION_BACKLOG_THRESHOLD=500
FIM_AGENT_INVESTIGATION_BACKLOG_CRITICAL_ONLY=true
FIM_AGENT_INVESTIGATION_SIGNATURE_CHECK=true
FIM_TRUSTED_MAINTENANCE_WINDOWS=

# Notifications
FIM_DESKTOP_NOTIFICATIONS=false
FIM_EMAIL_ENABLED=false
FIM_SMTP_HOST=
FIM_SMTP_PORT=587
FIM_SMTP_USER=
FIM_SMTP_PASSWORD=
FIM_EMAIL_FROM=fim@localhost
FIM_EMAIL_TO=
FIM_BATCH_INTERVAL=3600
